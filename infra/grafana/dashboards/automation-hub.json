{
  "__inputs": [],
  "__requires": [],
  "annotations": { "list": [] },
  "description": "Automation Hub — workflow executions, error tracking, node performance",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100, "title": "Execution Overview", "type": "row" },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{"color":"green","value":null}] } }, "overrides": [] },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "id": 1, "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "title": "Total Executions (1h)", "type": "stat",
      "targets": [{ "expr": "sum(increase(workflow_executions_total[1h]))", "legendFormat": "Total", "refId": "A" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{"color":"green","value":null},{"color":"yellow","value":1},{"color":"red","value":5}] } }, "overrides": [] },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "id": 2, "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "title": "Failed Executions (1h)", "type": "stat",
      "targets": [{ "expr": "sum(increase(workflow_executions_total{status=\"failed\"}[1h]))", "legendFormat": "Failed", "refId": "A" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "percent", "color": { "mode": "thresholds" }, "thresholds": { "steps": [{"color":"red","value":null},{"color":"yellow","value":80},{"color":"green","value":95}] } }, "overrides": [] },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "id": 3, "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "title": "Success Rate (1h)", "type": "stat",
      "targets": [{ "expr": "100 * sum(increase(workflow_executions_total{status=\"completed\"}[1h])) / clamp_min(sum(increase(workflow_executions_total[1h])), 1)", "legendFormat": "Success %", "refId": "A" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "ms", "color": { "mode": "thresholds" }, "thresholds": { "steps": [{"color":"green","value":null},{"color":"yellow","value":5000},{"color":"red","value":30000}] } }, "overrides": [] },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "id": 4, "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "title": "Avg Execution Duration (p50)", "type": "stat",
      "targets": [{ "expr": "histogram_quantile(0.50, sum(rate(workflow_execution_duration_ms_bucket[5m])) by (le))", "legendFormat": "p50", "refId": "A" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "ms", "color": { "mode": "thresholds" }, "thresholds": { "steps": [{"color":"green","value":null},{"color":"yellow","value":15000},{"color":"red","value":60000}] } }, "overrides": [] },
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "id": 5, "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "title": "Avg Execution Duration (p95)", "type": "stat",
      "targets": [{ "expr": "histogram_quantile(0.95, sum(rate(workflow_execution_duration_ms_bucket[5m])) by (le))", "legendFormat": "p95", "refId": "A" }]
    },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "lineWidth": 2, "fillOpacity": 10 } }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 5 },
      "id": 10, "options": { "tooltip": { "mode": "multi" } },
      "title": "Executions per minute (by status)", "type": "timeseries",
      "targets": [
        { "expr": "sum(rate(workflow_executions_total{status=\"completed\"}[1m])) * 60", "legendFormat": "completed", "refId": "A" },
        { "expr": "sum(rate(workflow_executions_total{status=\"failed\"}[1m])) * 60", "legendFormat": "failed", "refId": "B" },
        { "expr": "sum(rate(workflow_executions_total{status=\"started\"}[1m])) * 60", "legendFormat": "started", "refId": "C" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "ms", "custom": { "lineWidth": 2 } }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 5 },
      "id": 11, "title": "Execution Duration Percentiles", "type": "timeseries",
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(workflow_execution_duration_ms_bucket[5m])) by (le))", "legendFormat": "p50", "refId": "A" },
        { "expr": "histogram_quantile(0.90, sum(rate(workflow_execution_duration_ms_bucket[5m])) by (le))", "legendFormat": "p90", "refId": "B" },
        { "expr": "histogram_quantile(0.99, sum(rate(workflow_execution_duration_ms_bucket[5m])) by (le))", "legendFormat": "p99", "refId": "C" }
      ]
    },

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 13 },
      "id": 101, "title": "Node Performance", "type": "row" },

    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "id": 20, "title": "Node Executions by Type (rate/min)", "type": "timeseries",
      "targets": [{ "expr": "sum(rate(node_executions_total[1m])) by (node_type) * 60", "legendFormat": "{{node_type}}", "refId": "A" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "id": 21, "title": "Node Failures by Type (rate/min)", "type": "timeseries",
      "targets": [{ "expr": "sum(rate(node_executions_total{status=\"failed\"}[1m])) by (node_type) * 60", "legendFormat": "{{node_type}}", "refId": "A" }]
    },

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 22 },
      "id": 102, "title": "Error Tracking & Logs", "type": "row" },

    {
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 23 },
      "id": 30, "title": "Error Logs (execution failures)", "type": "logs",
      "options": { "dedupStrategy": "none", "enableLogDetails": true, "prettifyLogMessage": false, "showCommonLabels": false, "showLabels": true, "showTime": true, "sortOrder": "Descending", "wrapLogMessage": false },
      "targets": [{ "expr": "{app=\"automation-hub\",level=\"error\"}", "refId": "A" }]
    },
    {
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 33 },
      "id": 31, "title": "All Workflow Logs", "type": "logs",
      "options": { "dedupStrategy": "none", "enableLogDetails": true, "prettifyLogMessage": true, "showCommonLabels": false, "showLabels": true, "showTime": true, "sortOrder": "Descending", "wrapLogMessage": true },
      "targets": [{ "expr": "{app=\"automation-hub\"}", "refId": "A" }]
    }

  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["automation-hub", "workflows"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "name": "DS_PROMETHEUS",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "type": "datasource"
      },
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "name": "DS_LOKI",
        "options": [],
        "query": "loki",
        "refresh": 1,
        "type": "datasource"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Automation Hub",
  "uid": "automation-hub-main",
  "version": 1
}
