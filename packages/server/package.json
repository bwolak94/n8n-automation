{
  "name": "@automation-hub/server",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc --project tsconfig.json",
    "start": "node dist/server.js",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest --coverage",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist coverage",
    "seed:integrations": "tsx src/scripts/seedIntegrations.ts",
    "seed:templates": "tsx src/scripts/seedTemplatesRunner.ts",
    "migrate:node-packages": "tsx src/scripts/migrateNodePackages.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.36.3",
    "@automation-hub/shared": "workspace:*",
    "@socket.io/redis-adapter": "^8.3.0",
    "bullmq": "^5.7.0",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "envalid": "^8.0.0",
    "express": "^4.19.2",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "isolated-vm": "^6.1.2",
    "jsonwebtoken": "^9.0.2",
    "lodash": "^4.18.1",
    "mongoose": "^8.4.0",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.9.14",
    "pg": "^8.12.0",
    "prom-client": "^15.1.3",
    "socket.io": "^4.8.3",
    "swagger-ui-express": "^5.0.1",
    "vm2": "^3.9.19",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.0",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/lodash": "^4.17.24",
    "@types/node": "^20.14.0",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^6.4.14",
    "@types/pg": "^8.11.6",
    "@types/supertest": "^6.0.2",
    "@types/swagger-ui-express": "^4.1.8",
    "jest": "^29.7.0",
    "socket.io-client": "^4.8.3",
    "supertest": "^7.0.0",
    "ts-jest": "^29.1.0",
    "tsx": "^4.15.0",
    "typescript": "^5.4.0"
  }
}
