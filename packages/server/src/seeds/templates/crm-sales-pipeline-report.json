{
  "name": "Weekly Sales Pipeline Report",
  "category": "CRM",
  "description": "Generate a weekly summary of pipeline health: open deals by stage, total value, win rate last 90 days. Emails the report to sales leadership every Monday.",
  "author": "platform",
  "tags": ["crm", "pipeline", "report", "sales", "schedule"],
  "nodes": [
    {
      "id": "node-1",
      "type": "schedule_trigger",
      "category": "triggers",
      "label": "Every Monday 7am",
      "position": { "x": 100, "y": 200 },
      "config": { "cron": "0 7 * * 1", "timezone": "UTC" }
    },
    {
      "id": "node-2",
      "type": "database",
      "category": "actions",
      "label": "Pipeline Stats",
      "position": { "x": 350, "y": 200 },
      "config": {
        "dialect": "postgres",
        "credentialId": "",
        "operation": "query",
        "sql": "SELECT stage, COUNT(*) AS deal_count, SUM(value) AS total_value FROM deals WHERE status = 'open' GROUP BY stage ORDER BY stage",
        "maxRows": 20
      }
    },
    {
      "id": "node-3",
      "type": "database",
      "category": "actions",
      "label": "Win Rate Last 90 Days",
      "position": { "x": 350, "y": 380 },
      "config": {
        "dialect": "postgres",
        "credentialId": "",
        "operation": "query",
        "sql": "SELECT ROUND(100.0 * SUM(CASE WHEN status = 'won' THEN 1 ELSE 0 END) / COUNT(*), 2) AS win_rate FROM deals WHERE closed_at >= NOW() - INTERVAL '90 days'",
        "maxRows": 1
      }
    },
    {
      "id": "node-4",
      "type": "email",
      "category": "communication",
      "label": "Email Pipeline Report",
      "position": { "x": 700, "y": 280 },
      "config": {
        "transport": "smtp",
        "to": "sales-leadership@example.com",
        "subject": "Weekly Pipeline Report",
        "html": "<h2>Pipeline Summary</h2><h3>Open Deals by Stage</h3><pre>{{nodes.node-2.data.rows}}</pre><h3>Win Rate (90 days)</h3><p>{{nodes.node-3.data.rows[0].win_rate}}%</p>"
      }
    }
  ],
  "edges": [
    { "id": "e-1-2", "source": "node-1", "target": "node-2" },
    { "id": "e-1-3", "source": "node-1", "target": "node-3" },
    { "id": "e-2-4", "source": "node-2", "target": "node-4" },
    { "id": "e-3-4", "source": "node-3", "target": "node-4" }
  ]
}
