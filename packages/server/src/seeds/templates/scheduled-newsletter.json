{
  "name": "Weekly Newsletter Sender",
  "category": "Notifications",
  "description": "Fetch the latest content from your CMS every Monday morning and send a formatted HTML newsletter to your mailing list.",
  "author": "platform",
  "tags": ["newsletter", "email", "schedule", "cms", "marketing"],
  "nodes": [
    {
      "id": "node-1",
      "type": "schedule_trigger",
      "category": "triggers",
      "label": "Every Monday 8am",
      "position": { "x": 100, "y": 200 },
      "config": { "cron": "0 8 * * 1", "timezone": "UTC" }
    },
    {
      "id": "node-2",
      "type": "httpRequest",
      "category": "actions",
      "label": "Fetch Latest Posts",
      "position": { "x": 350, "y": 200 },
      "config": {
        "method": "GET",
        "url": "https://api.example.com/posts?limit=5&sort=createdAt:desc",
        "headers": { "Authorization": "Bearer YOUR_CMS_TOKEN" }
      }
    },
    {
      "id": "node-3",
      "type": "function",
      "category": "logic",
      "label": "Format Newsletter",
      "position": { "x": 600, "y": 200 },
      "config": {
        "code": "const posts = $input.posts || [];\nconst items = posts.map(p => `<li><a href='${p.url}'>${p.title}</a> — ${p.excerpt}</li>`).join('');\nreturn { html: `<h1>Weekly Update</h1><ul>${items}</ul><p><a href='https://example.com/unsubscribe'>Unsubscribe</a></p>` };",
        "timeoutMs": 3000
      }
    },
    {
      "id": "node-4",
      "type": "email",
      "category": "communication",
      "label": "Send Newsletter",
      "position": { "x": 850, "y": 200 },
      "config": {
        "transport": "smtp",
        "to": "newsletter@example.com",
        "subject": "Weekly Update — What's New This Week",
        "html": "{{nodes.node-3.data.html}}"
      }
    }
  ],
  "edges": [
    { "id": "e-1-2", "source": "node-1", "target": "node-2" },
    { "id": "e-2-3", "source": "node-2", "target": "node-3" },
    { "id": "e-3-4", "source": "node-3", "target": "node-4" }
  ]
}
