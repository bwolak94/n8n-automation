{
  "name": "AI Resume Screening",
  "category": "AI",
  "description": "Automatically screen job applications using AI. Scores resumes against job requirements and routes top candidates to the recruiting team with a summary.",
  "author": "platform",
  "tags": ["ai", "recruiting", "resume", "hiring", "hr"],
  "nodes": [
    {
      "id": "node-1",
      "type": "webhook_trigger",
      "category": "triggers",
      "label": "New Job Application",
      "position": { "x": 100, "y": 200 },
      "config": { "method": "POST" }
    },
    {
      "id": "node-2",
      "type": "ai_transform",
      "category": "ai",
      "label": "Screen Resume",
      "position": { "x": 350, "y": 200 },
      "config": {
        "prompt": "Screen this job application against the requirements. Return JSON: { score: 0-100, recommendation: 'advance'|'reject'|'review', strengths: string[], gaps: string[], summary: string }.\n\nJob Title: {{nodes.node-1.data.jobTitle}}\nRequirements: {{nodes.node-1.data.requirements}}\n\nResume:\n{{nodes.node-1.data.resumeText}}",
        "outputField": "screening"
      }
    },
    {
      "id": "node-3",
      "type": "database",
      "category": "actions",
      "label": "Store Screening Result",
      "position": { "x": 600, "y": 300 },
      "config": {
        "dialect": "postgres",
        "credentialId": "",
        "operation": "query",
        "sql": "INSERT INTO application_screening (application_id, score, recommendation, summary, screened_at) VALUES ('{{nodes.node-1.data.applicationId}}', {{nodes.node-2.data.screening.score}}, '{{nodes.node-2.data.screening.recommendation}}', '{{nodes.node-2.data.screening.summary}}', NOW())"
      }
    },
    {
      "id": "node-4",
      "type": "conditional",
      "category": "logic",
      "label": "Advance?",
      "position": { "x": 600, "y": 150 },
      "config": {
        "mode": "if",
        "conditions": [
          { "field": "{{nodes.node-2.data.screening.recommendation}}", "operator": "equals", "value": "advance" }
        ],
        "combinator": "and"
      }
    },
    {
      "id": "node-5",
      "type": "email",
      "category": "communication",
      "label": "Alert Recruiter",
      "position": { "x": 900, "y": 150 },
      "config": {
        "transport": "smtp",
        "to": "recruiting@example.com",
        "subject": "Strong Candidate: {{nodes.node-1.data.applicantName}} for {{nodes.node-1.data.jobTitle}} (Score: {{nodes.node-2.data.screening.score}}/100)",
        "html": "<h2>Candidate to Advance</h2><p><strong>{{nodes.node-1.data.applicantName}}</strong></p><p>Score: {{nodes.node-2.data.screening.score}}/100</p><p>{{nodes.node-2.data.screening.summary}}</p>"
      }
    }
  ],
  "edges": [
    { "id": "e-1-2", "source": "node-1", "target": "node-2" },
    { "id": "e-2-3", "source": "node-2", "target": "node-3" },
    { "id": "e-2-4", "source": "node-2", "target": "node-4" },
    { "id": "e-4-5", "source": "node-4", "target": "node-5", "sourceHandle": "true" }
  ]
}
