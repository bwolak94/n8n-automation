{
  "name": "Database Deduplication",
  "category": "Data Processing",
  "description": "Run a nightly deduplication job that finds and removes duplicate records in a database table based on email address, keeping the most recent entry.",
  "author": "platform",
  "tags": ["deduplication", "database", "cleanup", "postgres", "schedule"],
  "nodes": [
    {
      "id": "node-1",
      "type": "schedule_trigger",
      "category": "triggers",
      "label": "Nightly at 3am",
      "position": { "x": 100, "y": 200 },
      "config": { "cron": "0 3 * * *", "timezone": "UTC" }
    },
    {
      "id": "node-2",
      "type": "database",
      "category": "actions",
      "label": "Find Duplicates",
      "position": { "x": 350, "y": 200 },
      "config": {
        "dialect": "postgres",
        "credentialId": "",
        "operation": "query",
        "sql": "SELECT COUNT(*) AS duplicate_count FROM (SELECT email FROM contacts GROUP BY email HAVING COUNT(*) > 1) sub",
        "maxRows": 1
      }
    },
    {
      "id": "node-3",
      "type": "conditional",
      "category": "logic",
      "label": "Has Duplicates?",
      "position": { "x": 600, "y": 200 },
      "config": {
        "mode": "if",
        "conditions": [
          { "field": "{{nodes.node-2.data.rows[0].duplicate_count}}", "operator": "greaterThan", "value": "0" }
        ],
        "combinator": "and"
      }
    },
    {
      "id": "node-4",
      "type": "database",
      "category": "actions",
      "label": "Remove Duplicates",
      "position": { "x": 850, "y": 200 },
      "config": {
        "dialect": "postgres",
        "credentialId": "",
        "operation": "query",
        "sql": "DELETE FROM contacts WHERE id NOT IN (SELECT MAX(id) FROM contacts GROUP BY email)"
      }
    },
    {
      "id": "node-5",
      "type": "email",
      "category": "communication",
      "label": "Report Results",
      "position": { "x": 1100, "y": 200 },
      "config": {
        "transport": "smtp",
        "to": "data@example.com",
        "subject": "Deduplication complete — {{nodes.node-2.data.rows[0].duplicate_count}} groups removed",
        "html": "<p>Deduplication job completed. Removed {{nodes.node-2.data.rows[0].duplicate_count}} duplicate groups from contacts table.</p>"
      }
    }
  ],
  "edges": [
    { "id": "e-1-2", "source": "node-1", "target": "node-2" },
    { "id": "e-2-3", "source": "node-2", "target": "node-3" },
    { "id": "e-3-4", "source": "node-3", "target": "node-4", "sourceHandle": "true" },
    { "id": "e-4-5", "source": "node-4", "target": "node-5" }
  ]
}
