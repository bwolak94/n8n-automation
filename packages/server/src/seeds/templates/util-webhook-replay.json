{
  "name": "Webhook Replay Utility",
  "category": "Utilities",
  "description": "Replay failed webhook deliveries that were logged to the database. Useful for recovering from downstream outages without re-triggering the original event source.",
  "author": "platform",
  "tags": ["webhook", "replay", "recovery", "utilities", "reliability"],
  "nodes": [
    {
      "id": "node-1",
      "type": "webhookTrigger",
      "category": "triggers",
      "label": "Replay Request",
      "position": { "x": 100, "y": 200 },
      "config": { "method": "POST" }
    },
    {
      "id": "node-2",
      "type": "database",
      "category": "actions",
      "label": "Fetch Failed Webhooks",
      "position": { "x": 350, "y": 200 },
      "config": {
        "dialect": "postgres",
        "credentialId": "",
        "operation": "query",
        "sql": "SELECT id, endpoint_url, headers, payload, created_at FROM webhook_delivery_log WHERE status = 'failed' AND created_at > NOW() - INTERVAL '{{nodes.node-1.data.hoursBack}} hours' LIMIT 50",
        "maxRows": 50
      }
    },
    {
      "id": "node-3",
      "type": "loop",
      "category": "logic",
      "label": "Replay Each Webhook",
      "position": { "x": 600, "y": 200 },
      "config": {
        "inputField": "rows",
        "batchSize": 1,
        "collectResults": true,
        "continueOnError": true,
        "maxIterations": 50
      }
    },
    {
      "id": "node-4",
      "type": "httpRequest",
      "category": "actions",
      "label": "Re-deliver Webhook",
      "position": { "x": 850, "y": 200 },
      "loopNodeId": "node-3",
      "config": {
        "method": "POST",
        "url": "{{$item.value.endpoint_url}}",
        "headers": "{{$item.value.headers}}",
        "body": "{{$item.value.payload}}"
      }
    },
    {
      "id": "node-5",
      "type": "database",
      "category": "actions",
      "label": "Mark as Replayed",
      "position": { "x": 1100, "y": 200 },
      "config": {
        "dialect": "postgres",
        "credentialId": "",
        "operation": "query",
        "sql": "UPDATE webhook_delivery_log SET status = 'replayed', replayed_at = NOW() WHERE status = 'failed' AND created_at > NOW() - INTERVAL '{{nodes.node-1.data.hoursBack}} hours'"
      }
    }
  ],
  "edges": [
    { "id": "e-1-2", "source": "node-1", "target": "node-2" },
    { "id": "e-2-3", "source": "node-2", "target": "node-3" },
    { "id": "e-3-4", "source": "node-3", "target": "node-4" },
    { "id": "e-4-5", "source": "node-4", "target": "node-5" }
  ]
}
