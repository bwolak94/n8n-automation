{
  "name": "ETL Pipeline",
  "category": "Data Processing",
  "description": "Extract data from a REST API, transform it with a function node, and load the results into a PostgreSQL table. A classic ETL pattern on a nightly schedule.",
  "author": "platform",
  "tags": ["etl", "extract", "transform", "load", "database", "schedule"],
  "nodes": [
    {
      "id": "node-1",
      "type": "schedule_trigger",
      "category": "triggers",
      "label": "Nightly at 2am",
      "position": { "x": 100, "y": 200 },
      "config": { "cron": "0 2 * * *", "timezone": "UTC" }
    },
    {
      "id": "node-2",
      "type": "http_request",
      "category": "actions",
      "label": "Extract from API",
      "position": { "x": 350, "y": 200 },
      "config": {
        "method": "GET",
        "url": "https://api.source-system.example.com/data?since={{nodes.node-1.data.timestamp}}",
        "headers": { "Authorization": "Bearer YOUR_TOKEN" }
      }
    },
    {
      "id": "node-3",
      "type": "function",
      "category": "logic",
      "label": "Transform Records",
      "position": { "x": 600, "y": 200 },
      "config": {
        "code": "const records = $input.data || [];\nreturn records.map(r => ({ id: r.external_id, name: r.full_name, value: parseFloat(r.amount || 0), processed_at: new Date().toISOString() }));",
        "timeoutMs": 10000
      }
    },
    {
      "id": "node-4",
      "type": "loop",
      "category": "logic",
      "label": "Insert Each Record",
      "position": { "x": 850, "y": 200 },
      "config": {
        "inputField": "data",
        "batchSize": 1,
        "collectResults": true,
        "continueOnError": true,
        "maxIterations": 1000
      }
    },
    {
      "id": "node-5",
      "type": "database",
      "category": "actions",
      "label": "Upsert to PostgreSQL",
      "position": { "x": 1100, "y": 200 },
      "loopNodeId": "node-4",
      "config": {
        "dialect": "postgres",
        "credentialId": "",
        "operation": "query",
        "sql": "INSERT INTO etl_data (external_id, name, value, processed_at) VALUES ('{{$item.value.id}}', '{{$item.value.name}}', {{$item.value.value}}, '{{$item.value.processed_at}}') ON CONFLICT (external_id) DO UPDATE SET name = EXCLUDED.name, value = EXCLUDED.value, processed_at = EXCLUDED.processed_at"
      }
    }
  ],
  "edges": [
    { "id": "e-1-2", "source": "node-1", "target": "node-2" },
    { "id": "e-2-3", "source": "node-2", "target": "node-3" },
    { "id": "e-3-4", "source": "node-3", "target": "node-4" },
    { "id": "e-4-5", "source": "node-4", "target": "node-5" }
  ]
}
