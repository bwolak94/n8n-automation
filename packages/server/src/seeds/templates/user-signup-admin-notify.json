{
  "name": "New User Signup Admin Notify",
  "category": "Notifications",
  "description": "Notify the admin team via Slack and log to a database whenever a new user signs up. Useful for monitoring growth and spotting suspicious registrations.",
  "author": "platform",
  "tags": ["signup", "user", "admin", "slack", "notification"],
  "nodes": [
    {
      "id": "node-1",
      "type": "webhookTrigger",
      "category": "triggers",
      "label": "User Signup Webhook",
      "position": { "x": 100, "y": 200 },
      "config": { "method": "POST" }
    },
    {
      "id": "node-2",
      "type": "httpRequest",
      "category": "actions",
      "label": "Notify Slack #growth",
      "position": { "x": 350, "y": 100 },
      "config": {
        "method": "POST",
        "url": "https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK",
        "headers": { "Content-Type": "application/json" },
        "body": {
          "text": ":tada: New signup: *{{nodes.node-1.data.email}}* from {{nodes.node-1.data.country}}"
        }
      }
    },
    {
      "id": "node-3",
      "type": "database",
      "category": "actions",
      "label": "Log Signup",
      "position": { "x": 350, "y": 320 },
      "config": {
        "dialect": "postgres",
        "credentialId": "",
        "operation": "query",
        "sql": "INSERT INTO signup_log (email, country, signed_up_at) VALUES ('{{nodes.node-1.data.email}}', '{{nodes.node-1.data.country}}', NOW())"
      }
    }
  ],
  "edges": [
    { "id": "e-1-2", "source": "node-1", "target": "node-2" },
    { "id": "e-1-3", "source": "node-1", "target": "node-3" }
  ]
}
