{
  "name": "Kubernetes Pod Restart Alert",
  "category": "DevOps",
  "description": "Monitor Kubernetes pod restart counts via the API every 5 minutes. Alert the on-call team when any pod exceeds 5 restarts, indicating a crash loop.",
  "author": "platform",
  "tags": ["kubernetes", "k8s", "pods", "alert", "devops"],
  "nodes": [
    {
      "id": "node-1",
      "type": "schedule_trigger",
      "category": "triggers",
      "label": "Every 5 Minutes",
      "position": { "x": 100, "y": 200 },
      "config": { "cron": "*/5 * * * *", "timezone": "UTC" }
    },
    {
      "id": "node-2",
      "type": "httpRequest",
      "category": "actions",
      "label": "List Pod Statuses",
      "position": { "x": 350, "y": 200 },
      "config": {
        "method": "GET",
        "url": "https://YOUR_K8S_API/api/v1/namespaces/production/pods",
        "headers": { "Authorization": "Bearer YOUR_K8S_TOKEN" }
      }
    },
    {
      "id": "node-3",
      "type": "function",
      "category": "logic",
      "label": "Find CrashLooping Pods",
      "position": { "x": 600, "y": 200 },
      "config": {
        "code": "const pods = $input.items || [];\nconst crashing = pods.filter(p => p.status.containerStatuses?.some(c => c.restartCount > 5)).map(p => ({ name: p.metadata.name, restarts: p.status.containerStatuses[0].restartCount }));\nreturn { hasCrashing: crashing.length > 0, pods: crashing };",
        "timeoutMs": 3000
      }
    },
    {
      "id": "node-4",
      "type": "conditional",
      "category": "logic",
      "label": "Any Crashing?",
      "position": { "x": 850, "y": 200 },
      "config": {
        "mode": "if",
        "conditions": [
          { "field": "{{nodes.node-3.data.hasCrashing}}", "operator": "equals", "value": "true" }
        ],
        "combinator": "and"
      }
    },
    {
      "id": "node-5",
      "type": "httpRequest",
      "category": "actions",
      "label": "Slack CrashLoop Alert",
      "position": { "x": 1100, "y": 200 },
      "config": {
        "method": "POST",
        "url": "https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK",
        "headers": { "Content-Type": "application/json" },
        "body": { "text": ":rotating_light: CrashLoopBackOff detected in production!\n```{{nodes.node-3.data.pods}}```" }
      }
    }
  ],
  "edges": [
    { "id": "e-1-2", "source": "node-1", "target": "node-2" },
    { "id": "e-2-3", "source": "node-2", "target": "node-3" },
    { "id": "e-3-4", "source": "node-3", "target": "node-4" },
    { "id": "e-4-5", "source": "node-4", "target": "node-5", "sourceHandle": "true" }
  ]
}
