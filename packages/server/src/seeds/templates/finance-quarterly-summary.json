{
  "name": "Quarterly Financial Summary",
  "category": "Finance",
  "description": "Generate a comprehensive quarterly financial summary including revenue, expenses, profit margins, and YoY comparison. Emails to board members on the first day of each quarter.",
  "author": "platform",
  "tags": ["quarterly", "financial", "report", "revenue", "board"],
  "nodes": [
    {
      "id": "node-1",
      "type": "schedule_trigger",
      "category": "triggers",
      "label": "First Day of Quarter",
      "position": { "x": 100, "y": 200 },
      "config": { "cron": "0 8 1 1,4,7,10 *", "timezone": "UTC" }
    },
    {
      "id": "node-2",
      "type": "database",
      "category": "actions",
      "label": "Query Quarterly Revenue",
      "position": { "x": 350, "y": 200 },
      "config": {
        "dialect": "postgres",
        "credentialId": "",
        "operation": "query",
        "sql": "SELECT SUM(amount) AS revenue, COUNT(*) AS transaction_count, AVG(amount) AS avg_transaction FROM payments WHERE status = 'succeeded' AND created_at >= DATE_TRUNC('quarter', CURRENT_DATE - INTERVAL '1 quarter') AND created_at < DATE_TRUNC('quarter', CURRENT_DATE)",
        "maxRows": 1
      }
    },
    {
      "id": "node-3",
      "type": "http_request",
      "category": "actions",
      "label": "Fetch from Accounting API",
      "position": { "x": 350, "y": 380 },
      "config": {
        "method": "GET",
        "url": "https://api.quickbooks.example.com/reports/quarterly",
        "headers": { "Authorization": "Bearer YOUR_QB_TOKEN" }
      }
    },
    {
      "id": "node-4",
      "type": "email",
      "category": "communication",
      "label": "Email Board Report",
      "position": { "x": 750, "y": 280 },
      "config": {
        "transport": "smtp",
        "to": "board@example.com",
        "subject": "Q{{nodes.node-1.data.quarter}} Financial Summary",
        "html": "<h2>Quarterly Financial Summary</h2><h3>Revenue</h3><p><strong>${{nodes.node-2.data.rows[0].revenue}}</strong> across {{nodes.node-2.data.rows[0].transaction_count}} transactions</p><h3>P&L from Accounting</h3><pre>{{nodes.node-3.data.summary}}</pre>"
      }
    }
  ],
  "edges": [
    { "id": "e-1-2", "source": "node-1", "target": "node-2" },
    { "id": "e-1-3", "source": "node-1", "target": "node-3" },
    { "id": "e-2-4", "source": "node-2", "target": "node-4" },
    { "id": "e-3-4", "source": "node-3", "target": "node-4" }
  ]
}
