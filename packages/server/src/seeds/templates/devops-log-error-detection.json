{
  "name": "Log Error Pattern Detection",
  "category": "DevOps",
  "description": "Scan application logs every 10 minutes for known error patterns (OOM, segfault, 5xx spikes). Automatically creates incidents for critical patterns.",
  "author": "platform",
  "tags": ["logs", "error-detection", "monitoring", "incident", "devops"],
  "nodes": [
    {
      "id": "node-1",
      "type": "schedule_trigger",
      "category": "triggers",
      "label": "Every 10 Minutes",
      "position": { "x": 100, "y": 200 },
      "config": { "cron": "*/10 * * * *", "timezone": "UTC" }
    },
    {
      "id": "node-2",
      "type": "httpRequest",
      "category": "actions",
      "label": "Query CloudWatch Logs",
      "position": { "x": 350, "y": 200 },
      "config": {
        "method": "POST",
        "url": "https://logs.YOUR_REGION.amazonaws.com/",
        "headers": { "Content-Type": "application/x-amz-json-1.1", "X-Amz-Target": "Logs_20140328.FilterLogEvents" },
        "body": {
          "logGroupName": "/app/production",
          "filterPattern": "?OOM ?segfault ?\"CRITICAL\" ?\"out of memory\"",
          "startTime": "{{nodes.node-1.data.timestamp}}"
        }
      }
    },
    {
      "id": "node-3",
      "type": "conditional",
      "category": "logic",
      "label": "Errors Found?",
      "position": { "x": 600, "y": 200 },
      "config": {
        "mode": "if",
        "conditions": [
          { "field": "{{nodes.node-2.data.events.length}}", "operator": "greaterThan", "value": "0" }
        ],
        "combinator": "and"
      }
    },
    {
      "id": "node-4",
      "type": "httpRequest",
      "category": "actions",
      "label": "Create Incident",
      "position": { "x": 850, "y": 200 },
      "config": {
        "method": "POST",
        "url": "https://api.incident.io/v2/incidents",
        "headers": { "Authorization": "Bearer YOUR_INCIDENT_IO_TOKEN", "Content-Type": "application/json" },
        "body": {
          "name": "Critical log pattern detected in production",
          "summary": "{{nodes.node-2.data.events.length}} critical log events found",
          "severity": "critical"
        }
      }
    }
  ],
  "edges": [
    { "id": "e-1-2", "source": "node-1", "target": "node-2" },
    { "id": "e-2-3", "source": "node-2", "target": "node-3" },
    { "id": "e-3-4", "source": "node-3", "target": "node-4", "sourceHandle": "true" }
  ]
}
