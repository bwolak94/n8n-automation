{
  "name": "Overdue Invoice Escalation",
  "category": "Finance",
  "description": "Escalate invoices overdue by 60+ days to collections. Automatically updates invoice status, notifies the collections team, and suspends the customer account.",
  "author": "platform",
  "tags": ["collections", "overdue", "invoice", "escalation", "finance"],
  "nodes": [
    {
      "id": "node-1",
      "type": "schedule_trigger",
      "category": "triggers",
      "label": "Daily at 9am",
      "position": { "x": 100, "y": 200 },
      "config": { "cron": "0 9 * * *", "timezone": "UTC" }
    },
    {
      "id": "node-2",
      "type": "database",
      "category": "actions",
      "label": "Find 60+ Day Overdue",
      "position": { "x": 350, "y": 200 },
      "config": {
        "dialect": "postgres",
        "credentialId": "",
        "operation": "query",
        "sql": "UPDATE invoices SET status = 'collections' WHERE status = 'unpaid' AND due_date < CURRENT_DATE - 60 RETURNING id, customer_id, customer_email, amount, due_date",
        "maxRows": 200
      }
    },
    {
      "id": "node-3",
      "type": "conditional",
      "category": "logic",
      "label": "Any Escalated?",
      "position": { "x": 600, "y": 200 },
      "config": {
        "mode": "if",
        "conditions": [
          { "field": "{{nodes.node-2.data.rowCount}}", "operator": "greaterThan", "value": "0" }
        ],
        "combinator": "and"
      }
    },
    {
      "id": "node-4",
      "type": "email",
      "category": "communication",
      "label": "Notify Collections Team",
      "position": { "x": 850, "y": 200 },
      "config": {
        "transport": "smtp",
        "to": "collections@example.com",
        "subject": "{{nodes.node-2.data.rowCount}} invoices escalated to collections",
        "html": "<h2>Collections Escalation</h2><p>{{nodes.node-2.data.rowCount}} invoices are now 60+ days overdue and have been moved to collections status.</p><pre>{{nodes.node-2.data.rows}}</pre>"
      }
    }
  ],
  "edges": [
    { "id": "e-1-2", "source": "node-1", "target": "node-2" },
    { "id": "e-2-3", "source": "node-2", "target": "node-3" },
    { "id": "e-3-4", "source": "node-3", "target": "node-4", "sourceHandle": "true" }
  ]
}
