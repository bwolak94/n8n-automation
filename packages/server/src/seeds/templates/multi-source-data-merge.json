{
  "name": "Multi-Source Data Merge",
  "category": "Data Processing",
  "description": "Fetch data from two different APIs in parallel, merge the results using a join node, and store the unified dataset in the database.",
  "author": "platform",
  "tags": ["merge", "join", "parallel", "api", "database"],
  "nodes": [
    {
      "id": "node-1",
      "type": "schedule_trigger",
      "category": "triggers",
      "label": "Nightly at 1am",
      "position": { "x": 100, "y": 200 },
      "config": { "cron": "0 1 * * *", "timezone": "UTC" }
    },
    {
      "id": "node-2",
      "type": "httpRequest",
      "category": "actions",
      "label": "Fetch CRM Contacts",
      "position": { "x": 350, "y": 100 },
      "config": {
        "method": "GET",
        "url": "https://api.crm.example.com/contacts",
        "headers": { "Authorization": "Bearer YOUR_CRM_TOKEN" }
      }
    },
    {
      "id": "node-3",
      "type": "httpRequest",
      "category": "actions",
      "label": "Fetch Billing Records",
      "position": { "x": 350, "y": 300 },
      "config": {
        "method": "GET",
        "url": "https://api.billing.example.com/customers",
        "headers": { "Authorization": "Bearer YOUR_BILLING_TOKEN" }
      }
    },
    {
      "id": "node-4",
      "type": "merge",
      "category": "logic",
      "label": "Join on Email",
      "position": { "x": 650, "y": 200 },
      "config": {
        "mode": "mergeByKey",
        "inputCount": 2,
        "joinKey": "email",
        "joinType": "left"
      }
    },
    {
      "id": "node-5",
      "type": "database",
      "category": "actions",
      "label": "Upsert Unified Contacts",
      "position": { "x": 900, "y": 200 },
      "config": {
        "dialect": "postgres",
        "credentialId": "",
        "operation": "query",
        "sql": "INSERT INTO unified_contacts (email, crm_id, billing_id, merged_at) SELECT email, crm_id, billing_id, NOW() FROM json_populate_recordset(null::unified_contacts, '{{nodes.node-4.data}}') ON CONFLICT (email) DO UPDATE SET billing_id = EXCLUDED.billing_id, merged_at = EXCLUDED.merged_at"
      }
    }
  ],
  "edges": [
    { "id": "e-1-2", "source": "node-1", "target": "node-2" },
    { "id": "e-1-3", "source": "node-1", "target": "node-3" },
    { "id": "e-2-4", "source": "node-2", "target": "node-4" },
    { "id": "e-3-4", "source": "node-3", "target": "node-4" },
    { "id": "e-4-5", "source": "node-4", "target": "node-5" }
  ]
}
