{
  "name": "Database Export to External API",
  "category": "Data Processing",
  "description": "Query a database table and push the results to an external analytics or reporting API. Useful for syncing data warehouses or third-party BI tools.",
  "author": "platform",
  "tags": ["database", "export", "api", "sync", "analytics"],
  "nodes": [
    {
      "id": "node-1",
      "type": "schedule_trigger",
      "category": "triggers",
      "label": "Daily at 6am",
      "position": { "x": 100, "y": 200 },
      "config": { "cron": "0 6 * * *", "timezone": "UTC" }
    },
    {
      "id": "node-2",
      "type": "database",
      "category": "actions",
      "label": "Export Yesterday Data",
      "position": { "x": 350, "y": 200 },
      "config": {
        "dialect": "postgres",
        "credentialId": "",
        "operation": "query",
        "sql": "SELECT user_id, event_type, properties, created_at FROM events WHERE created_at::date = CURRENT_DATE - 1 ORDER BY created_at",
        "maxRows": 10000
      }
    },
    {
      "id": "node-3",
      "type": "function",
      "category": "logic",
      "label": "Format for Analytics API",
      "position": { "x": 600, "y": 200 },
      "config": {
        "code": "const rows = $input.rows || [];\nreturn { events: rows.map(r => ({ userId: r.user_id, event: r.event_type, properties: r.properties, timestamp: r.created_at })), count: rows.length };",
        "timeoutMs": 10000
      }
    },
    {
      "id": "node-4",
      "type": "http_request",
      "category": "actions",
      "label": "Push to Analytics API",
      "position": { "x": 850, "y": 200 },
      "config": {
        "method": "POST",
        "url": "https://api.analytics.example.com/import",
        "headers": { "Content-Type": "application/json", "X-Api-Key": "YOUR_KEY" },
        "body": { "events": "{{nodes.node-3.data.events}}" }
      }
    }
  ],
  "edges": [
    { "id": "e-1-2", "source": "node-1", "target": "node-2" },
    { "id": "e-2-3", "source": "node-2", "target": "node-3" },
    { "id": "e-3-4", "source": "node-3", "target": "node-4" }
  ]
}
