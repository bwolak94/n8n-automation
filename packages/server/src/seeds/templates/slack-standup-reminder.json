{
  "name": "Slack Standup Reminder",
  "category": "Notifications",
  "description": "Send a daily standup reminder to your Slack channel every weekday morning. Uses a schedule trigger and an HTTP request to the Slack API.",
  "author": "platform",
  "tags": ["slack", "notifications", "schedule", "standup", "team"],
  "nodes": [
    {
      "id": "node-1",
      "type": "schedule_trigger",
      "category": "triggers",
      "label": "Weekdays at 9am",
      "position": { "x": 100, "y": 200 },
      "config": {
        "cron": "0 9 * * 1-5",
        "timezone": "America/New_York"
      }
    },
    {
      "id": "node-2",
      "type": "http_request",
      "category": "actions",
      "label": "Post to Slack",
      "position": { "x": 350, "y": 200 },
      "config": {
        "method": "POST",
        "url": "https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK",
        "headers": { "Content-Type": "application/json" },
        "body": {
          "text": ":wave: Good morning team! Time for standup. Please share:\n1. What did you do yesterday?\n2. What are you doing today?\n3. Any blockers?"
        }
      }
    }
  ],
  "edges": [
    { "id": "e-1-2", "source": "node-1", "target": "node-2" }
  ]
}
