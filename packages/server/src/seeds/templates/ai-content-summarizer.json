{
  "name": "AI Content Summarizer",
  "category": "AI",
  "description": "Fetch an article from a URL, use Claude AI to summarize it, and email the summary. Great for staying on top of industry news without reading every article.",
  "author": "platform",
  "tags": ["ai", "claude", "summarization", "email", "content"],
  "nodes": [
    {
      "id": "node-1",
      "type": "webhookTrigger",
      "category": "triggers",
      "label": "Summarize Article",
      "position": { "x": 100, "y": 200 },
      "config": {
        "method": "POST",
        "description": "POST { url, email } to trigger summarization"
      }
    },
    {
      "id": "node-2",
      "type": "httpRequest",
      "category": "actions",
      "label": "Fetch Article",
      "position": { "x": 350, "y": 200 },
      "config": {
        "method": "GET",
        "url": "{{nodes.node-1.data.url}}",
        "headers": {}
      }
    },
    {
      "id": "node-3",
      "type": "aiTransform",
      "category": "ai",
      "label": "Summarize with Claude",
      "position": { "x": 600, "y": 200 },
      "config": {
        "prompt": "Please provide a concise 3-paragraph summary of the following article content. Focus on the key insights and actionable takeaways.\n\n{{nodes.node-2.data.body}}",
        "outputField": "summary"
      }
    },
    {
      "id": "node-4",
      "type": "email",
      "category": "communication",
      "label": "Email Summary",
      "position": { "x": 850, "y": 200 },
      "config": {
        "transport": "smtp",
        "to": "{{nodes.node-1.data.email}}",
        "subject": "Article Summary: {{nodes.node-1.data.url}}",
        "html": "<h2>AI Summary</h2><p>{{nodes.node-3.data.summary}}</p><hr><p><small>Original: <a href=\"{{nodes.node-1.data.url}}\">{{nodes.node-1.data.url}}</a></small></p>"
      }
    }
  ],
  "edges": [
    { "id": "e-1-2", "source": "node-1", "target": "node-2" },
    { "id": "e-2-3", "source": "node-2", "target": "node-3" },
    { "id": "e-3-4", "source": "node-3", "target": "node-4" }
  ]
}
