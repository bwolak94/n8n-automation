{
  "name": "SSL Certificate Expiry Check",
  "category": "DevOps",
  "description": "Check SSL certificate expiry for your domains every day. Send an email alert when any certificate expires within 30 days to prevent outages.",
  "author": "platform",
  "tags": ["ssl", "certificate", "expiry", "security", "devops"],
  "nodes": [
    {
      "id": "node-1",
      "type": "schedule_trigger",
      "category": "triggers",
      "label": "Daily at 7am",
      "position": { "x": 100, "y": 200 },
      "config": { "cron": "0 7 * * *", "timezone": "UTC" }
    },
    {
      "id": "node-2",
      "type": "httpRequest",
      "category": "actions",
      "label": "Check SSL via API",
      "position": { "x": 350, "y": 200 },
      "config": {
        "method": "GET",
        "url": "https://ssl-checker.example.com/api/check?domains=example.com,api.example.com,app.example.com",
        "headers": { "Authorization": "Bearer YOUR_TOKEN" }
      }
    },
    {
      "id": "node-3",
      "type": "function",
      "category": "logic",
      "label": "Filter Expiring Soon",
      "position": { "x": 600, "y": 200 },
      "config": {
        "code": "const certs = $input.certificates || [];\nconst expiring = certs.filter(c => c.daysUntilExpiry <= 30);\nreturn { hasExpiring: expiring.length > 0, expiring, count: expiring.length };",
        "timeoutMs": 2000
      }
    },
    {
      "id": "node-4",
      "type": "conditional",
      "category": "logic",
      "label": "Any Expiring?",
      "position": { "x": 850, "y": 200 },
      "config": {
        "mode": "if",
        "conditions": [
          { "field": "{{nodes.node-3.data.hasExpiring}}", "operator": "equals", "value": "true" }
        ],
        "combinator": "and"
      }
    },
    {
      "id": "node-5",
      "type": "email",
      "category": "communication",
      "label": "Alert DevOps Team",
      "position": { "x": 1100, "y": 200 },
      "config": {
        "transport": "smtp",
        "to": "devops@example.com",
        "subject": "ACTION REQUIRED: {{nodes.node-3.data.count}} SSL certs expire within 30 days",
        "html": "<h2>SSL Certificate Expiry Warning</h2><pre>{{nodes.node-3.data.expiring}}</pre><p>Please renew these certificates immediately.</p>"
      }
    }
  ],
  "edges": [
    { "id": "e-1-2", "source": "node-1", "target": "node-2" },
    { "id": "e-2-3", "source": "node-2", "target": "node-3" },
    { "id": "e-3-4", "source": "node-3", "target": "node-4" },
    { "id": "e-4-5", "source": "node-4", "target": "node-5", "sourceHandle": "true" }
  ]
}
